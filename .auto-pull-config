# Script tự động chạy khi mở terminal
# Thêm vào file ~/.bashrc hoặc ~/.zshrc:
# source /workspaces/OOP_N02_T3_2_2025_Group7/.auto-pull-config

auto_set_java_default() {
    local sdkman_init="$HOME/.sdkman/bin/sdkman-init.sh"
    local java_version="21.0.9-ms"

    if [ -s "$sdkman_init" ]; then
        # Load SDKMAN only when needed, then switch the default JDK.
        # shellcheck disable=SC1090
        . "$sdkman_init"

        if sdk list java | grep -q "${java_version}"; then
            sdk default java "$java_version" >/dev/null 2>&1
        fi
    fi
}

auto_git_pull() {
    if [ -d ".git" ]; then
        echo "🔄 Đang pull code mới nhất..."
        git pull origin main --quiet
        if [ $? -eq 0 ]; then
            echo "✅ Code đã được cập nhật!"
        else
            echo "❌ Không thể pull code. Vui lòng kiểm tra lại."
        fi
    fi
}

# Chạy auto pull khi vào thư mục workspace
if [[ "$PWD" == *"OOP_N02_T3_2_2025_Group7"* ]]; then
    auto_set_java_default
    auto_git_pull
fi
